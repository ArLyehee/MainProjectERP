<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.gaebalfan.erp.mapper.ReceiptMapper">

    <resultMap id="ReceiptResultMap" type="com.gaebalfan.erp.domain.Receipt">
        <id     property="receiptId"   column="receipt_id"/>
        <result property="poId"        column="po_id"/>
        <result property="productId"   column="product_id"/>
        <result property="quantity"    column="quantity"/>
        <result property="receiptDate" column="receipt_date"/>
        <result property="createdAt"   column="created_at"/>
        <result property="productName" column="product_name"/>
    </resultMap>

    <select id="findAll" resultMap="ReceiptResultMap">
        SELECT r.*, p.product_name
        FROM receipts r
        LEFT JOIN products p ON r.product_id = p.product_id
        ORDER BY r.created_at DESC
    </select>

    <insert id="insert" parameterType="com.gaebalfan.erp.domain.Receipt"
            useGeneratedKeys="true" keyProperty="receiptId">
        INSERT INTO receipts (po_id, product_id, quantity, receipt_date, created_at)
        VALUES (#{poId}, #{productId}, #{quantity}, #{receiptDate}, NOW())
    </insert>

    <delete id="delete">
        DELETE FROM receipts WHERE receipt_id = #{receiptId}
    </delete>

</mapper>