<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.gaebalfan.erp.mapper.ShipmentMapper">

    <resultMap id="ShipmentResultMap" type="com.gaebalfan.erp.domain.Shipment">
        <id     property="shipmentId"   column="shipment_id"/>
        <result property="productId"    column="product_id"/>
        <result property="warehouseId"  column="warehouse_id"/>
        <result property="quantity"     column="quantity"/>
        <result property="shipmentDate" column="shipment_date"/>
        <result property="destination"  column="destination"/>
        <result property="productName"  column="product_name"/>
        <result property="warehouseName" column="warehouse_name"/>
    </resultMap>

    <select id="findAll" resultMap="ShipmentResultMap">
        SELECT s.*, p.product_name, w.warehouse_name
        FROM shipments s
        LEFT JOIN products p ON s.product_id = p.product_id
        LEFT JOIN warehouses w ON s.warehouse_id = w.warehouse_id
        ORDER BY s.shipment_id DESC
    </select>

    <select id="findById" resultMap="ShipmentResultMap">
        SELECT * FROM shipments WHERE shipment_id = #{shipmentId}
    </select>

    <insert id="insert" parameterType="com.gaebalfan.erp.domain.Shipment"
            useGeneratedKeys="true" keyProperty="shipmentId">
        INSERT INTO shipments (product_id, warehouse_id, quantity, shipment_date, destination)
        VALUES (#{productId}, #{warehouseId}, #{quantity}, #{shipmentDate}, #{destination})
    </insert>

    <delete id="delete">
        DELETE FROM shipments WHERE shipment_id = #{shipmentId}
    </delete>

</mapper>
