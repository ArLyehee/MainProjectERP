<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.gaebalfan.erp.mapper.PurchaseOrderMapper">

    <resultMap id="PurchaseOrderResultMap" type="com.gaebalfan.erp.domain.PurchaseOrder">
        <id     property="poId"         column="po_id"/>
        <result property="supplierId"   column="supplier_id"/>
        <result property="orderDate"    column="order_date"/>
        <result property="status"       column="status"/>
        <result property="supplierName" column="supplier_name"/>
    </resultMap>

    <select id="findAll" resultMap="PurchaseOrderResultMap">
        SELECT po.*, s.supplier_name
        FROM purchase_orders po
        LEFT JOIN suppliers s ON po.supplier_id = s.supplier_id
        ORDER BY po.po_id DESC
    </select>

    <select id="findById" resultMap="PurchaseOrderResultMap">
        SELECT * FROM purchase_orders WHERE po_id = #{poId}
    </select>

    <insert id="insert" parameterType="com.gaebalfan.erp.domain.PurchaseOrder"
            useGeneratedKeys="true" keyProperty="poId">
        INSERT INTO purchase_orders (supplier_id, order_date, status)
        VALUES (#{supplierId}, #{orderDate}, #{status})
    </insert>

    <update id="updateStatus">
        UPDATE purchase_orders SET status = #{status}
        WHERE po_id = #{poId}
    </update>

    <delete id="delete">
        DELETE FROM purchase_orders WHERE po_id = #{poId}
    </delete>

</mapper>