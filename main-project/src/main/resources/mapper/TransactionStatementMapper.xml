<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.gaebalfan.erp.mapper.TransactionStatementMapper">

    <resultMap id="StatementResultMap" type="com.gaebalfan.erp.domain.TransactionStatement">
        <id     property="statementId"   column="statement_id"/>
        <result property="statementNo"   column="statement_no"/>
        <result property="issueDate"     column="issue_date"/>
        <result property="customerName"  column="customer_name"/>
        <result property="supplyName"    column="supply_name"/>
        <result property="customerAddr"  column="customer_addr"/>
        <result property="customerTel"   column="customer_tel"/>
        <result property="customerBizNo" column="customer_biz_no"/>
        <result property="totalAmount"   column="total_amount"/>
        <result property="taxAmount"     column="tax_amount"/>
        <result property="grandTotal"    column="grand_total"/>
        <result property="notes"         column="notes"/>
        <result property="managerName"   column="manager_name"/>
        <result property="createdAt"     column="created_at"/>
    </resultMap>

    <resultMap id="ItemResultMap" type="com.gaebalfan.erp.domain.TransactionStatementItem">
        <id     property="itemId"      column="item_id"/>
        <result property="statementId" column="statement_id"/>
        <result property="itemName"    column="item_name"/>
        <result property="quantity"    column="quantity"/>
        <result property="unitPrice"   column="unit_price"/>
        <result property="amount"      column="amount"/>
    </resultMap>

    <select id="count" resultType="int">
        SELECT COUNT(*) FROM transaction_statements
    </select>

    <select id="findAllPaged" resultMap="StatementResultMap">
        SELECT * FROM transaction_statements ORDER BY statement_id DESC
        LIMIT #{size} OFFSET #{offset}
    </select>

    <select id="findAll" resultMap="StatementResultMap">
        SELECT * FROM transaction_statements ORDER BY statement_id DESC
    </select>

    <select id="findById" resultMap="StatementResultMap">
        SELECT * FROM transaction_statements WHERE statement_id = #{statementId}
    </select>

    <select id="findItemsByStatementId" resultMap="ItemResultMap">
        SELECT * FROM transaction_statement_items WHERE statement_id = #{statementId} ORDER BY item_id
    </select>

    <insert id="insert" parameterType="com.gaebalfan.erp.domain.TransactionStatement"
            useGeneratedKeys="true" keyProperty="statementId">
        INSERT INTO transaction_statements
            (statement_no, issue_date, customer_name, supply_name, customer_addr, customer_tel,
             customer_biz_no, total_amount, tax_amount, grand_total, notes, manager_name)
        VALUES
            (#{statementNo}, #{issueDate}, #{customerName}, #{supplyName}, #{customerAddr}, #{customerTel},
             #{customerBizNo}, #{totalAmount}, #{taxAmount}, #{grandTotal}, #{notes}, #{managerName})
    </insert>

    <insert id="insertItem" parameterType="com.gaebalfan.erp.domain.TransactionStatementItem"
            useGeneratedKeys="true" keyProperty="itemId">
        INSERT INTO transaction_statement_items (statement_id, item_name, quantity, unit_price, amount)
        VALUES (#{statementId}, #{itemName}, #{quantity}, #{unitPrice}, #{amount})
    </insert>

    <update id="update" parameterType="com.gaebalfan.erp.domain.TransactionStatement">
        UPDATE transaction_statements SET
            issue_date      = #{issueDate},
            customer_name   = #{customerName},
            supply_name     = #{supplyName},
            customer_addr   = #{customerAddr},
            customer_tel    = #{customerTel},
            customer_biz_no = #{customerBizNo},
            total_amount    = #{totalAmount},
            tax_amount      = #{taxAmount},
            grand_total     = #{grandTotal},
            notes           = #{notes},
            manager_name    = #{managerName}
        WHERE statement_id = #{statementId}
    </update>

    <delete id="deleteItemsByStatementId">
        DELETE FROM transaction_statement_items WHERE statement_id = #{statementId}
    </delete>

    <delete id="delete">
        DELETE FROM transaction_statements WHERE statement_id = #{statementId}
    </delete>

    <select id="findMaxStatementNo" resultType="string">
        SELECT MAX(statement_no) FROM transaction_statements WHERE statement_no LIKE CONCAT(#{prefix}, '%')
    </select>

</mapper>
