<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.gaebalfan.erp.mapper.BomMapper">

    <resultMap id="BomResultMap" type="com.gaebalfan.erp.domain.Bom">
        <id     property="bomId"       column="bom_id"/>
        <result property="productId"   column="product_id"/>
        <result property="description" column="description"/>
        <result property="productName" column="product_name"/>
    </resultMap>

    <resultMap id="BomItemResultMap" type="com.gaebalfan.erp.domain.BomItem">
        <id     property="bomItemId"     column="bom_item_id"/>
        <result property="bomId"         column="bom_id"/>
        <result property="componentName" column="component_name"/>
        <result property="quantity"      column="quantity"/>
    </resultMap>

    <select id="findAll" resultMap="BomResultMap">
        SELECT b.*, p.product_name
        FROM bom b
        LEFT JOIN products p ON b.product_id = p.product_id
        ORDER BY b.bom_id DESC
    </select>

    <select id="findById" resultMap="BomResultMap">
        SELECT b.*, p.product_name
        FROM bom b
        LEFT JOIN products p ON b.product_id = p.product_id
        WHERE b.bom_id = #{bomId}
    </select>

    <select id="findItemsByBomId" resultMap="BomItemResultMap">
        SELECT * FROM bom_items WHERE bom_id = #{bomId} ORDER BY bom_item_id
    </select>

    <insert id="insertBom" parameterType="com.gaebalfan.erp.domain.Bom"
            useGeneratedKeys="true" keyProperty="bomId">
        INSERT INTO bom (product_id, description)
        VALUES (#{productId}, #{description})
    </insert>

    <insert id="insertBomItem" parameterType="com.gaebalfan.erp.domain.BomItem"
            useGeneratedKeys="true" keyProperty="bomItemId">
        INSERT INTO bom_items (bom_id, component_name, quantity)
        VALUES (#{bomId}, #{componentName}, #{quantity})
    </insert>

    <delete id="deleteBomItem">
        DELETE FROM bom_items WHERE bom_item_id = #{bomItemId}
    </delete>

</mapper>
